# Copy this file to .env and fill in values.

# Only needed if you authenticate with an API key.
# If you already use Claude Code with a Claude subscription login,
# you can leave this blank and the SDK will reuse that session.
ANTHROPIC_API_KEY=

# WebSocket server bind address/port that the ESP32 (and browser test
# client) will connect to. 0.0.0.0 lets the ESP32 reach it over your LAN.
BRIDGE_HOST=0.0.0.0
BRIDGE_PORT=8765

# Working directory the Claude session operates in (its "project").
SESSION_CWD=.

# Speech-to-text model size for push-to-talk (tiny/base/small/medium).
# "base" is a good speed/accuracy tradeoff on CPU.
WHISPER_MODEL=base
